# ============================================================================
# Open WebUI Environment Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================================

# --------------------------------------------------------------------------
# Trilium MCP Server (Optional)
# Used by mcpo for Trilium integration
# --------------------------------------------------------------------------
TRILIUM_API_KEY=your_trilium_api_key_here
TRILIUM_URL=http://192.168.0.46:9910

# --------------------------------------------------------------------------
# Ollama / OpenAI API Configuration
# Base URLs for LLM inference
# --------------------------------------------------------------------------
OLLAMA_BASE_URL=http://192.168.0.46:11434
OPENAI_API_BASE_URL=http://192.168.0.46:11434/v1

# --------------------------------------------------------------------------
# Open WebUI Configuration
# Secret key for session management (generate a random string)
# --------------------------------------------------------------------------
WEBUI_SECRET_KEY=your_secret_key_here_generate_random_string

# --------------------------------------------------------------------------
# Open Terminal API Key
# Used by open-terminal service and auto-connect in open-webui
# --------------------------------------------------------------------------
OPEN_TERMINAL_API_KEY=your_terminal_api_key_here

# --------------------------------------------------------------------------
# OAuth / SSO Configuration (Cloudflare Access)
# Required for authentication
# --------------------------------------------------------------------------
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# --------------------------------------------------------------------------
# OpenID Provider Configuration
# Cloudflare Access OIDC configuration URL and redirect URI
# --------------------------------------------------------------------------
OPENID_PROVIDER_URL=https://your-domain.cloudflareaccess.com/cdn-cgi/access/sso/oidc/{id}/.well-known/openid-configuration
OPENID_REDIRECT_URI=https://your-domain.tld/oauth/oidc/callback

# --------------------------------------------------------------------------
# SearXNG Configuration
# Secret key for session signing (generate with `openssl rand -hex 32`)
# Note: SearXNG expects env var SEARXNG_SECRET, not SEARXNG_SECRET_KEY
# --------------------------------------------------------------------------
SEARXNG_SECRET=your_searxng_secret_key_here_generate_random_string

# --------------------------------------------------------------------------
# Portainer MCP
# Portainer API key from web ui
# Portainer environment ID that should be connected
# --------------------------------------------------------------------------
PORTAINER_API_KEY=your_portainer_api_key
PORTAINER_ENV_ID=3

# --------------------------------------------------------------------------
# Notes:
# - All URLs should point to your local network IP (e.g., 192.168.x.x)
# - WEBUI_SECRET_KEY: Generate with `openssl rand -hex 32` or similar
# - OAUTH_CLIENT_ID/SECRET: Get from Cloudflare Access dashboard
# - TRILIUM_API_KEY: From Trilium note-taking app settings
# ============================================================================
